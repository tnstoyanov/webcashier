<!DOCTYPE html>
<html lang="en">
<head>
    <!-- CRITICAL: Guard Array.prototype.reduce at the ABSOLUTE BEGINNING before any other scripts -->
    <script>
        // Override reduce IMMEDIATELY to prevent polyfills from failing when testing on null/undefined
        const originalReduce = Array.prototype.reduce;
        Array.prototype.reduce = function(...args) {
            if (this == null) {
                // Silently return undefined instead of throwing - fixes polyfill detection
                return undefined;
            }
            return originalReduce.apply(this, args);
        };
        console.log('[EARLY-GUARD] Array.prototype.reduce guarded at page start');
    </script>
    
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebCashier</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto+Condensed:wght@300;400;500;600&display=swap" rel="stylesheet">
    <!-- Use Bootstrap CDN instead of local files to reduce build size -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebCashier.styles.css" asp-append-version="true" />
    
    <!-- CRITICAL: Load jQuery FIRST before any external scripts that might depend on it -->
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.min.js"></script>
    <script>
        // Wrap jQuery selector engine to suppress :hidden/:visible errors
        if (typeof $ !== 'undefined') {
            // Override jQuery's error handler to suppress selector errors
            const originalError = window.onerror;
            window.onerror = function(msg, url, line, col, error) {
                // Suppress :hidden/:visible pseudo-selector errors
                if (msg && (msg.includes("':hidden'") || msg.includes("':visible'"))) {
                    console.debug('Suppressed jQuery pseudo-selector error:', msg);
                    return true; // Prevent default error handling
                }
                return originalError ? originalError(msg, url, line, col, error) : false;
            };
        }
        
        // CRITICAL: Restore jQuery pseudo-selectors that were removed in newer jQuery versions
        if (typeof $ !== 'undefined' && $.expr) {
            try {
                // Add support for :hidden and :visible selectors
                $.extend($.expr[':'], {
                    hidden: function(element) {
                        return element.offsetWidth <= 0 && element.offsetHeight <= 0 || 
                               $(element).css('display') === 'none';
                    },
                    visible: function(element) {
                        return element.offsetWidth > 0 || element.offsetHeight > 0 || 
                               $(element).css('display') !== 'none';
                    }
                });
                
                // Also override jQuery.find to suppress :hidden/:visible related errors
                const originalFind = $.find;
                $.find = function(selector, context) {
                    try {
                        return originalFind.apply(this, arguments);
                    } catch (e) {
                        if (e.message && (e.message.includes(':hidden') || e.message.includes(':visible'))) {
                            console.debug('Suppressed find error for pseudo-selector');
                            return [];
                        }
                        throw e;
                    }
                };
                
                console.log('jQuery pseudo-selectors (:hidden, :visible) restored with error suppression');
            } catch (e) {
                console.warn('Could not restore jQuery selectors:', e.message);
            }
        }
        console.log('Array.prototype.reduce guarded');
    </script>
    
    <!-- Nuvei Simply Connect Scripts and Styles -->
    <script id="nuvei-scplugin-script" type="text/javascript" defer src="https://cdn.safecharge.com/safecharge_resources/v1/checkout/checkout.js"></script>
    <link id="nuveiCheckoutCss" type="text/css" rel="stylesheet" href="https://cdn.safecharge.com/safecharge_resources/v1/checkout/cc.css">
    
    <!-- Nuvei Apple Pay IFrame Support -->
    <script src="https://cdn.safecharge.com/safecharge_resources/v1/sc_applepay.min.js"></script>
</head>
<body>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - WebCashier
        </div>
    </footer>
    <!-- Bootstrap JS already loaded in head, don't duplicate jQuery -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
